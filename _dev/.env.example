# PrestaShop version to use (easily changeable)
PS_VERSION=8.1

# MySQL configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=prestashop

# Ports (can be changed if running multiple versions simultaneously)
PS_PORT=8080
MYSQL_PORT=3306
PMA_PORT=8081

# PHP version (optional, e.g. 8.3, 8.4, 8.5 — leave empty for the default bundled with the PS image)
PHP_VERSION=

# Full image tag used by docker-compose (auto-updated by make switch, do not edit manually)
PS_IMAGE_TAG=8.1

# Docker Compose project name (used for volume isolation between versions)
COMPOSE_PROJECT_NAME=ps81
