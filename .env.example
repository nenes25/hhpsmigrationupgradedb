# Version de PrestaShop à utiliser (modifiable facilement)
PS_VERSION=8.1

# Configuration MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=prestashop

# Ports (modifiables si vous lancez plusieurs versions simultanément)
PS_PORT=8080
MYSQL_PORT=3306
PMA_PORT=8081
